# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file!

# ── Database ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# ── JWT Authentication ────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here
JWT_EXPIRE=7d

# ── Encryption key (for stored third-party credentials) ────────
# MUST be different from JWT_SECRET
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_random_hex_here

# ── Email Configuration (Gmail) ───────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Server ────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── Frontend URL (set to your Railway domain in production) ───
CLIENT_URL=https://your-app.up.railway.app

# ── ShippersHub API ───────────────────────────────────────────
SHIPPERSHUB_EMAIL=your_email
SHIPPERSHUB_PASSWORD=your_password

# ── Open Exchange Rates ───────────────────────────────────────
OPEN_EXCHANGE_RATES_APP_ID=your_app_id_here
